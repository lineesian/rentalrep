# Copy this file to .env.local and fill in your Supabase credentials
# Found at: https://supabase.com/dashboard → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only — never expose to the client
# Found at: Supabase → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Random secret for Vercel Cron authentication — generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here
